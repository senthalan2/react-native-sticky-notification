<?xml version="1.0" encoding="utf-8"?>
<!--
  Root layout for the custom big-content view (expanded notification).
  The header area is static; the buttons_container is populated at runtime
  via RemoteViews.addView() so there is no fixed limit on button count.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- ── Header ──────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/notification_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="" />

        <TextView
            android:id="@+id/notification_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="2dp"
            android:text="" />

        <TextView
            android:id="@+id/notification_subtext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp"
            android:visibility="gone"
            android:text="" />
    </LinearLayout>

    <!-- ── Divider ─────────────────────────────────────────────────────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33000000"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="4dp" />

    <!-- ── Dynamic button rows inserted here at runtime ──────────────────
         StickyNotificationHelper uses RemoteViews.addView() to append one
         notification_action_row per row of buttons.  The count and layout
         depend on the `actions`, `maxButtons`, and `buttonsPerRow` config.  -->
    <LinearLayout
        android:id="@+id/buttons_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

</LinearLayout>
