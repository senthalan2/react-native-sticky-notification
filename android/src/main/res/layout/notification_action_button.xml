<?xml version="1.0" encoding="utf-8"?>
<!--
  Template for a single action button inside a notification_action_row.
  layout_weight="1" on the root ensures equal-width sharing when multiple
  buttons are added to the same row via RemoteViews.addView().

  IDs used by StickyNotificationHelper:
    action_button  – root FrameLayout; receives the click PendingIntent
    action_bg      – ImageView used as a dynamic rounded background
                     (bitmap generated at runtime; gone when not needed)
    action_icon    – optional icon (gone when no icon is provided)
    action_text    – button label
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/action_button"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:clickable="true"
    android:focusable="true">

    <!-- Dynamic rounded-rectangle background rendered as a Bitmap at runtime.
         scaleType="fitXY" stretches it to fill the full button area. -->
    <ImageView
        android:id="@+id/action_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:visibility="gone" />

    <!-- Icon + label stacked vertically, centred over the background layer. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="8dp">

        <ImageView
            android:id="@+id/action_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:scaleType="centerInside"
            android:visibility="gone" />

        <TextView
            android:id="@+id/action_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center"
            android:layout_marginTop="2dp"
            android:text="" />

    </LinearLayout>

</FrameLayout>
