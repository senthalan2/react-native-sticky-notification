<?xml version="1.0" encoding="utf-8"?>
<!--
  Template for a single action button inside a notification_action_row.
  layout_weight="1" on the root view ensures equal-width sharing when
  multiple buttons are added to the same row via RemoteViews.addView().

  IDs set by StickyNotificationHelper:
    action_button  – root container; receives the click PendingIntent
    action_icon    – optional drawable icon (hidden when no icon is set)
    action_text    – button label
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/action_button"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:orientation="vertical"
    android:gravity="center"
    android:clickable="true"
    android:focusable="true"
    android:padding="8dp">

    <ImageView
        android:id="@+id/action_icon"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:scaleType="centerInside"
        android:visibility="gone" />

    <TextView
        android:id="@+id/action_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:gravity="center"
        android:layout_marginTop="2dp"
        android:text="" />

</LinearLayout>
